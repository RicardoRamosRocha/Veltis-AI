@model OrizonAI.Domain.Entities.AIProvider

@{
    ViewData["Title"] = "Detalhes do Provedor";
}

<section class="crud-hero">
    <div class="crud-eyebrow">
        <i class="bi bi-eye"></i>
        Detalhes do provedor
    </div>

    <h1 class="crud-title">@Model.DisplayName</h1>

    <p class="crud-subtitle">
        Visualize as configurações, prioridades, capacidades e status operacional
        deste provedor de inteligência artificial.
    </p>
</section>

<section class="premium-form-card">

    <div class="premium-form-header">
        <h2>Informações do provedor</h2>
        <p>Dados utilizados para integração e operação da plataforma.</p>
    </div>

    <div class="premium-form-body">

        <div class="form-section-title">
            <i class="bi bi-fingerprint"></i>
            Identificação
        </div>

        <div class="details-grid">

            <div class="detail-card">
                <span>Nome</span>
                <strong>@Model.DisplayName</strong>
            </div>

            <div class="detail-card">
                <span>Tipo</span>
                <strong>@Model.Type</strong>
            </div>

            <div class="detail-card">
                <span>Base URL</span>
                <strong>@Model.BaseUrl</strong>
            </div>

            <div class="detail-card">
                <span>Status</span>

                @if (Model.Active)
                {
                    <span class="status-badge status-active">
                        <i class="bi bi-check-circle-fill"></i>
                        Ativo
                    </span>
                }
                else
                {
                    <span class="status-badge status-inactive">
                        <i class="bi bi-x-circle-fill"></i>
                        Inativo
                    </span>
                }

            </div>

        </div>

        <hr class="divider-soft" />

        <div class="form-section-title">
            <i class="bi bi-sliders"></i>
            Configuração operacional
        </div>

        <div class="details-grid">

            <div class="detail-card">
                <span>Prioridade</span>
                <strong>@Model.Priority</strong>
            </div>

            <div class="detail-card">
                <span>Timeout</span>
                <strong>@Model.TimeoutSeconds segundos</strong>
            </div>

            <div class="detail-card">
                <span>Tentativas</span>
                <strong>@Model.RetryCount</strong>
            </div>

        </div>

        <hr class="divider-soft" />

        <div class="form-section-title">
            <i class="bi bi-stars"></i>
            Capacidades suportadas
        </div>

        <div class="capability-grid">

            <div class="capability-card">
                <span>Streaming</span>
                <strong>@(Model.SupportsStreaming ? "Disponível" : "Indisponível")</strong>
            </div>

            <div class="capability-card">
                <span>Visão</span>
                <strong>@(Model.SupportsVision ? "Disponível" : "Indisponível")</strong>
            </div>

            <div class="capability-card">
                <span>Áudio</span>
                <strong>@(Model.SupportsAudio ? "Disponível" : "Indisponível")</strong>
            </div>

            <div class="capability-card">
                <span>Status Operacional</span>
                <strong>@(Model.Active ? "Ativo" : "Inativo")</strong>
            </div>

        </div>

    </div>

    <div class="premium-form-footer">

        <a asp-area="Admin"
           asp-controller="AIProviders"
           asp-action="Index"
           class="btn btn-outline-secondary premium-btn">

            <i class="bi bi-arrow-left"></i>
            Voltar

        </a>

        <a asp-area="Admin"
           asp-controller="AIProviders"
           asp-action="Edit"
           asp-route-id="@Model.Id"
           class="premium-btn premium-btn-primary">

            <i class="bi bi-pencil-square"></i>
            Editar Provedor

        </a>

    </div>

</section>