@model IEnumerable<OrizonAI.Domain.Entities.AIProvider>

@{
    ViewData["Title"] = "Provedores de IA";
}

<section class="crud-hero">
    <div class="crud-eyebrow">
        <i class="bi bi-cloud-fill"></i>
        Provedores de IA
    </div>

    <h1 class="crud-title">Gerenciar Provedores de IA</h1>

    <p class="crud-subtitle">
        Gerencie integrações com provedores de inteligência artificial, prioridade,
        disponibilidade, recursos suportados e status operacional da plataforma.
    </p>
</section>

<section class="premium-table-card">
    <div class="premium-table-header">
        <div>
            <h2>Provedores cadastrados</h2>
            <p>
                Todos os provedores configurados para uso na infraestrutura da Orizon AI.
            </p>
        </div>

        <a asp-area="Admin"
           asp-controller="AIProviders"
           asp-action="Create"
           class="premium-btn premium-btn-primary">
            <i class="bi bi-plus-circle"></i>
            Novo Provedor
        </a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="table premium-table">
                <thead>
                    <tr>
                        <th>Provedor</th>
                        <th>Tipo</th>
                        <th>Base URL</th>
                        <th>Prioridade</th>
                        <th>Status</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>

                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="entity-name">
                                <div class="entity-icon">
                                    <i class="bi bi-cloud-fill"></i>
                                </div>

                                <div>
                                    <div class="entity-title">
                                        @item.DisplayName
                                    </div>

                                    <div class="entity-subtitle">
                                        Provedor de IA
                                    </div>
                                </div>
                            </div>
                        </td>

                        <td>
                            <span class="identifier-pill">
                                @item.Type
                            </span>
                        </td>

                        <td>
                            <span class="identifier-pill">
                                @item.BaseUrl
                            </span>
                        </td>

                        <td>
                            @item.Priority
                        </td>

                        <td>
                            @if (item.Active)
                            {
                                <span class="status-badge status-active">
                                    <i class="bi bi-check-circle-fill"></i>
                                    Ativo
                                </span>
                            }
                            else
                            {
                                <span class="status-badge status-inactive">
                                    <i class="bi bi-x-circle-fill"></i>
                                    Inativo
                                </span>
                            }
                        </td>

                        <td>
                            <div class="action-buttons">
                                <a asp-area="Admin"
                                   asp-controller="AIProviders"
                                   asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="Detalhes">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-area="Admin"
                                   asp-controller="AIProviders"
                                   asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Editar">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a asp-area="Admin"
                                   asp-controller="AIProviders"
                                   asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger"
                                   title="Excluir">
                                    <i class="bi bi-trash3"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-cloud-plus"></i>

            <h3>Nenhum provedor cadastrado</h3>

            <p>
                Cadastre seu primeiro provedor para começar a integrar modelos de IA.
            </p>

            <a asp-area="Admin"
               asp-controller="AIProviders"
               asp-action="Create"
               class="premium-btn premium-btn-primary">
                <i class="bi bi-plus-circle"></i>
                Cadastrar Provedor
            </a>
        </div>
    }
</section>