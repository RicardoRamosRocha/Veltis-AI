<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Orizon AI</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin-premium.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/OrizonAI.Web.styles.css" asp-append-version="true" />

    <style>
        :root {
            --Orizon-bg: #eef3fb;
            --Orizon-sidebar: #070d1c;
            --Orizon-sidebar-2: #0b1224;
            --Orizon-text: #0f172a;
            --Orizon-muted: #64748b;
            --Orizon-border: rgba(148, 163, 184, .22);
            --Orizon-primary: #2563eb;
            --Orizon-primary-2: #7c3aed;
            --Orizon-card: rgba(255, 255, 255, .82);
        }

        * {
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }

        body {
            margin: 0;
            color: var(--Orizon-text);
            background:
                radial-gradient(circle at top right, rgba(37, 99, 235, .12), transparent 30%),
                radial-gradient(circle at bottom left, rgba(124, 58, 237, .10), transparent 28%),
                var(--Orizon-bg);
        }

        .app-shell {
            min-height: 100vh;
            display: grid;
            grid-template-columns: 280px 1fr;
        }

        .app-sidebar {
            position: sticky;
            top: 0;
            height: 100vh;
            padding: 24px 18px;
            background:
                radial-gradient(circle at top left, rgba(37, 99, 235, .32), transparent 28%),
                linear-gradient(180deg, var(--Orizon-sidebar), var(--Orizon-sidebar-2));
            color: #fff;
            box-shadow: 24px 0 70px rgba(15, 23, 42, .18);
            z-index: 10;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 4px 6px 28px;
        }

        .brand-logo {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: grid;
            place-items: center;
            font-weight: 900;
            color: #fff;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            box-shadow: 0 18px 40px rgba(37, 99, 235, .35);
        }

        .brand-name {
            font-weight: 900;
            letter-spacing: -.04em;
            line-height: 1;
        }

        .brand-subtitle {
            color: rgba(255,255,255,.48);
            font-size: .78rem;
            margin-top: 4px;
        }

        .sidebar-section {
            margin: 22px 0 10px;
            padding: 0 10px;
            color: rgba(255,255,255,.38);
            font-size: .72rem;
            font-weight: 800;
            letter-spacing: .1em;
            text-transform: uppercase;
        }

        .side-nav {
            display: grid;
            gap: 6px;
        }

        .side-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 13px;
            border-radius: 15px;
            color: rgba(255,255,255,.72);
            text-decoration: none;
            font-weight: 700;
            transition: all .18s ease;
        }

        .side-link i {
            font-size: 1.08rem;
            color: rgba(255,255,255,.54);
        }

        .side-link:hover {
            color: #fff;
            background: rgba(255,255,255,.08);
            transform: translateX(3px);
        }

        .side-link.active {
            color: #fff;
            background: linear-gradient(135deg, rgba(37,99,235,.95), rgba(124,58,237,.88));
            box-shadow: 0 16px 34px rgba(37, 99, 235, .22);
        }

        .side-link.active i {
            color: #fff;
        }

        .sidebar-card {
            position: absolute;
            left: 18px;
            right: 18px;
            bottom: 22px;
            padding: 18px;
            border-radius: 22px;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.10);
        }

        .sidebar-card-title {
            font-weight: 850;
            margin-bottom: 6px;
        }

        .sidebar-card-text {
            color: rgba(255,255,255,.54);
            font-size: .82rem;
            margin-bottom: 14px;
        }

        .app-main {
            min-width: 0;
        }

        .topbar {
            position: sticky;
            top: 0;
            z-index: 9;
            min-height: 78px;
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(255,255,255,.74);
            border-bottom: 1px solid rgba(226,232,240,.85);
            backdrop-filter: blur(20px);
        }

        .topbar-title {
            margin: 0;
            font-size: 1rem;
            font-weight: 900;
            letter-spacing: -.03em;
        }

        .topbar-subtitle {
            color: var(--Orizon-muted);
            font-size: .86rem;
        }

        .topbar-actions {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .topbar-pill {
            border: 1px solid rgba(226,232,240,.95);
            background: rgba(255,255,255,.78);
            color: #334155;
            border-radius: 999px;
            padding: 9px 13px;
            font-size: .86rem;
            font-weight: 800;
            text-decoration: none;
        }

        .user-chip {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px 8px 8px;
            border-radius: 999px;
            background: #fff;
            border: 1px solid rgba(226,232,240,.95);
            box-shadow: 0 10px 28px rgba(15, 23, 42, .06);
            font-weight: 800;
        }

        .user-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: grid;
            place-items: center;
            color: #fff;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            font-size: .82rem;
            font-weight: 900;
        }

        .content-wrap {
            padding: 32px;
        }

        footer {
            display: none;
        }

        .btn-primary {
            border: 0;
            border-radius: 14px;
            font-weight: 800;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            box-shadow: 0 16px 36px rgba(37, 99, 235, .20);
        }

        .btn-outline-primary,
        .btn-outline-secondary,
        .btn-outline-danger {
            border-radius: 12px;
            font-weight: 800;
        }

        .card {
            border: 1px solid rgba(226, 232, 240, .95);
            border-radius: 24px;
            box-shadow: 0 22px 60px rgba(15, 23, 42, .07);
        }

        @@media (max-width: 992px) {
            .app-shell {
                grid-template-columns: 1fr;
            }

            .app-sidebar {
                position: relative;
                height: auto;
                border-radius: 0 0 28px 28px;
            }

            .sidebar-card {
                position: static;
                margin-top: 22px;
            }

            .topbar {
                padding: 16px 20px;
            }

            .content-wrap {
                padding: 22px;
            }
        }
    </style>
</head>

<body>
    <div class="app-shell">
        <aside class="app-sidebar">
            <div class="brand">
                <div class="brand-logo">V</div>
                <div>
                    <div class="brand-name">Orizon AI</div>
                    <div class="brand-subtitle">AI Infrastructure SaaS</div>
                </div>
            </div>

            <div class="sidebar-section">Principal</div>

            <nav class="side-nav">
                <a class="side-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill"></i>
                    Dashboard
                </a>

                <a class="side-link" asp-area="Admin" asp-controller="Companies" asp-action="Index">
                    <i class="bi bi-buildings-fill"></i>
                    Empresas
                </a>

                <a class="side-link" asp-area="Admin" asp-controller="Customers" asp-action="Index">
                    <i class="bi bi-people-fill"></i>
                    Clientes
                </a>

                <a class="side-link" asp-area="Admin" asp-controller="Plans" asp-action="Index">
                    <i class="bi bi-layers-fill"></i>
                    Planos
                </a>
            </nav>

            <div class="sidebar-section">Inteligência Artificial</div>

            <nav class="side-nav">
                <a class="side-link" asp-area="Admin" asp-controller="AIProviders" asp-action="Index">
                    <i class="bi bi-cloud-fill"></i>
                    Provedores
                </a>

                <a class="side-link" asp-area="Admin" asp-controller="AIModels" asp-action="Index">
                    <i class="bi bi-cpu-fill"></i>
                    Modelos
                </a>

                <a class="side-link" href="#">
                    <i class="bi bi-activity"></i>
                    Uso & Tokens
                </a>

                <a class="side-link" href="#">
                    <i class="bi bi-credit-card-2-front-fill"></i>
                    Créditos
                </a>
            </nav>

            <div class="sidebar-card">
                <div class="sidebar-card-title">Ambiente Demo</div>
                <div class="sidebar-card-text">
                    Interface premium preparada para apresentação comercial.
                </div>
                <span class="badge text-bg-light">Preview</span>
            </div>
        </aside>

        <main class="app-main">
            <header class="topbar">
                <div>
                    <h1 class="topbar-title">Painel Administrativo</h1>
                    <div class="topbar-subtitle">Gestão da plataforma Orizon AI</div>
                </div>

                <div class="topbar-actions">
                    <a href="#" class="topbar-pill">
                        <i class="bi bi-bell"></i>
                    </a>

                    <div class="user-chip">
                        <div class="user-avatar">R</div>
                        Admin
                    </div>

                    <a class="btn btn-sm btn-outline-danger" href="#">
                        Sair
                    </a>
                </div>
            </header>

            <div class="content-wrap">
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>